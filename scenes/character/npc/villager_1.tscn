[node name="villager1_farhan" type="CharacterBody2D" unique_id=267873462]
scale = Vector2(1.25, 1.25)
script = ExtResource("1_461j4")
dialogic_character = ExtResource("2_5udq3")
char_name = "Farhan Ishraq"
initial_dialogue = "...Zahra. It's been a long time. I don't— look, I can't really talk right now, alright? Everyone's already looking at me like I did something. My own uncle. I just got back to this town a few months ago and now this happens. Great timing, right?"
dialogue_lines = Array[String](["You think I don't know what people are saying? 'The nephew comes back, and suddenly Chacha's dead and the land's up for grabs.' I loved him, whatever anyone thinks. I just— I made a mistake. That's all I'm saying right now.", "That cloth... that's from my sleeve, isn't it. Okay. Okay, listen — I let someone into the shrine that night. He said he just wanted to look at the amulet up close, said he was writing about local heirlooms for some collector's journal, I don't know, I believed him. I didn't think— I never thought Chacha would even be there that late. When he came out and started shouting I panicked and ran. I didn't touch him, Zahra, I swear on everything, I didn't touch him.", "Fine. Fine! His name is Anwar. He offered me half of whatever it sold for — said Chacha would never even notice it gone for a few weeks, said he had a buyer already lined up. I said yes because I was angry, because I thought I deserved something after everyone forgot about me for ten years. I never wanted him dead. You have to believe that."])
motive = "Resentment over inheritance and years of family distance made him an easy accomplice for Anwar — he let Anwar into the shrine and has been silenced by guilt and threats since, but did not commit the killing."

