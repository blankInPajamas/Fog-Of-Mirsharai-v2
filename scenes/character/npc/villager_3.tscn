[node name="villager3_karim" type="CharacterBody2D" unique_id=267873462]
scale = Vector2(1.25, 1.25)
script = ExtResource("1_n2rnc")
dialogic_character = ExtResource("2_8wlv5")
char_name = "Karim Master"
initial_dialogue = "Zahra? Little Zahra, all grown up... in a week like this. I still can't believe it. Rafiq Dadu, gone. I was at the forge till late, alone, hammering out a plough blade for the Hossain family. Didn't hear a thing. This town's never had a night like this before."
dialogue_lines = Array[String](["You want to know about the money? Fine — yes, I owed him. Owed him plenty, for two years running. Everyone knew it. Go ahead, say what you're thinking. I know how it looks.", "...You found the ledger. Then you already know. He crossed the debt out himself, three weeks back. Said, 'Karim, a man shouldn't carry a stone he's already paid for.' I never even thanked him properly. I've been sitting with that instead of grief, if I'm honest with you."])
motive = "Owed Rafiq a large debt — appears to be a strong motive, but the debt was forgiven weeks before the murder. Alibi: asleep drunk in the tea stall corner, confirmed by Nasrin."

