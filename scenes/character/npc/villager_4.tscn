[node name="villager4_imam_yusuf" type="CharacterBody2D" unique_id=267873462]
scale = Vector2(1.25, 1.25)
script = ExtResource("1_68nkp")
dialogic_character = ExtResource("2_f7xb6")
char_name = "Imam Yusuf"
initial_dialogue = "Peace be upon you, child. A dark day for Mirsharai. Rafiq and I did not always see eye to eye, may Allah forgive us both our stubbornness, but he was a good man. I led prayers late into the night — ask anyone who was there."
dialogue_lines = Array[String](["You want to know what we argued about? The Shonali Doa. I believed it belonged to the mosque, to all of us — not locked in one family's box. Rafiq disagreed. We argued about it for years. I won't pretend otherwise to spare myself suspicion.", "That ledger page — yes, I know it. Rafiq and I had nearly settled the matter, in fact, the week before he died. He'd written me a letter agreeing to a compromise, the amulet displayed publicly twice a year, blessed by both of us. I have that letter still, if you want to see for yourself that our quarrel was ending, not boiling over."])
motive = "Ideological disagreement with Rafiq over who should hold the amulet — a plausible motive undercut by a solid alibi (leading late prayers, multiple witnesses) and a nearly-resolved dispute."

