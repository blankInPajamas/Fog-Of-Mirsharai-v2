; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="fog-of-mirsharai-v2"
run/main_scene="uid://bbtxqp8f4c3b1"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="uid://c2t65sbm7kpko"

[autoload]

Global="*uid://cmjajbvysjsls"
TransitionScene="*uid://6d4eqf3livau"
Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

directories/dch_directory={
"anwar": "res://styles/anwar.dch",
"farhan": "res://styles/farhan.dch",
"imam_yusuf": "res://styles/imam_yusuf.dch",
"karim": "res://styles/karim.dch",
"nasrin": "res://styles/nasrin.dch",
"priya": "res://styles/priya.dch"
}
directories/dtl_directory={
"anwar": "res://timelines/anwar.dtl",
"farhan": "res://timelines/farhan.dtl",
"imam_yusuf": "res://timelines/imam_yusuf.dtl",
"karim": "res://timelines/karim.dtl",
"nasrin": "res://timelines/nasrin.dtl",
"priya": "res://timelines/priya.dtl"
}
layout/style_directory={
"": "res://styles/textbubble.tres",
"textbubble": "res://styles/textbubble.tres"
}
layout/style_list=["res://styles/textbubble.tres"]
layout/default_style="res://styles/textbubble.tres"
text/letter_speed=0.01
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
save/autosave_delay=60.0
save/encryption_on_exports_only=true
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
text/autopauses={}
audio/channel_defaults={
"": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

[global_group]

zahra="the main player/detective"

